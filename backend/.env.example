# Server
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (omit to reflect any origin)
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=

# Auth (use long, random values; these are the only JWT secrets used)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Email (Nodemailer / Gmail)
EMAIL=
PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Swagger (optional: override the production server base URL)
SWAGGER_SERVER_URL=
