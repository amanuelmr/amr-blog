# Base URL of the backend API (include the /api/v1 prefix).
#
# Local development: point directly at your backend, e.g.
#   NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
#
# Production (recommended): use the same-origin proxy — set this to the
# relative path so the browser calls the frontend domain and Next rewrites it
# to the backend (no CORS, first-party cookies):
#   NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Backend origin that the proxy (next.config rewrites) forwards /api/* to.
# Only needed in production when using the same-origin proxy above.
BACKEND_URL=https://amr-blog-backend.vercel.app
